@model RestroManagement.DbModels.FoodItem

@{
    ViewData["Title"] = (Model?.Id > 0 ? "Edit" : "Create") + " Food Item";
    var allCategories = ViewBag.Categories as List<RestroManagement.DbModels.MenuCategory> ?? new List<RestroManagement.DbModels.MenuCategory>();
    var selectedCategoryIds = Model?.Categories?.Select(c => c.CategoryId).ToList() ?? new List<int>();
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-link p-0 text-decoration-none text-muted mb-2">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
    <h2 class="fw-bold">@ViewData["Title"]</h2>
</div>

<form asp-action="@(Model?.Id > 0 ? "Edit" : "Create")" enctype="multipart/form-data">
    <div class="row">
        <div class="col-lg-8">
            <div class="card p-4 mb-4">
                <h5 class="fw-bold mb-4">Basic Information</h5>
                @if (Model?.Id > 0) { <input type="hidden" asp-for="Id" /> }
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Masala Dosa" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="DietaryPreference" class="form-label fw-semibold"></label>
                        <select asp-for="DietaryPreference" asp-items="Html.GetEnumSelectList<RestroManagement.DbModels.DietaryPreference>()" class="form-select"></select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="PriceCalculationMethod" class="form-label fw-semibold"></label>
                        <select asp-for="PriceCalculationMethod" asp-items="Html.GetEnumSelectList<RestroManagement.DbModels.PriceCalculationMethod>()" class="form-select"></select>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Food Image</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" onchange="previewImage(this)" />
                    <div class="mt-3">
                        <img id="imagePreview" src="@(string.IsNullOrEmpty(Model?.ImageUrl) ? "#" : Model.ImageUrl)" 
                             class="rounded @(string.IsNullOrEmpty(Model?.ImageUrl) ? "d-none" : "")" 
                             style="max-width: 200px; height: auto;" />
                    </div>
                    @if (Model?.Id > 0 && !string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <input type="hidden" asp-for="ImageUrl" />
                    }
                </div>

                <div class="form-check form-switch mt-3">
                    <input class="form-check-input" type="checkbox" asp-for="IsAvailable">
                    <label class="form-check-label fw-bold" asp-for="IsAvailable">Item Available for Order</label>
                </div>
            </div>

            @if (Model?.Id > 0)
            {
                <div class="card p-4 mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold m-0">Portions & Pricing</h5>
                        <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#addPortionModal">
                            <i class="bi bi-plus-lg"></i> Add Portion
                        </button>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Portion Name</th>
                                    <th>Price</th>
                                    <th>Cost</th>
                                    <th>Base Qty</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Portions != null && Model.Portions.Any())
                                {
                                    foreach (var p in Model.Portions)
                                    {
                                        <tr>
                                            <td class="fw-bold">@p.Name</td>
                                            <td>₹@p.Price</td>
                                            <td>₹@p.Cost</td>
                                            <td>@p.BaseQuantity</td>
                                            <td class="text-end">
                                                <button type="submit" asp-action="DeletePortion" asp-route-id="@p.Id" class="btn btn-sm text-danger" onclick="return confirm('Delete this portion?')">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="5" class="text-center text-muted py-3">No portions added yet.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card p-4 mb-4">
                <h5 class="fw-bold mb-4">Menu Categories</h5>
                <div style="max-height: 300px; overflow-y: auto;">
                    @foreach (var cat in allCategories)
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" name="selectedCategories" value="@cat.Id" id="cat_@cat.Id" @(selectedCategoryIds.Contains(cat.Id) ? "checked" : "")>
                            <label class="form-check-label" for="cat_@cat.Id">
                                @cat.Name
                            </label>
                        </div>
                    }
                </div>
            </div>

            <div class="card p-4 bg-light">
                <button type="submit" class="btn btn-primary btn-lg w-100 mb-2">
                    <i class="bi bi-save"></i> Save Food Item
                </button>
                <small class="text-muted text-center d-block">Last Updated: @Model?.LastUpdated.ToString("g")</small>
            </div>
        </div>
    </div>
</form>

@if (Model?.Id > 0)
{
    <!-- Modal -->
    <div class="modal fade" id="addPortionModal" tabindex="-1">
        <div class="modal-dialog">
            <form asp-action="AddPortion">
                <input type="hidden" name="FoodItemId" value="@Model.Id" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Add Portion</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Portion Name (e.g. Full, 1kg)</label>
                            <input name="Name" class="form-control" required />
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label">Price</label>
                                <input name="Price" type="number" step="0.01" class="form-control" required />
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label">Cost</label>
                                <input name="Cost" type="number" step="0.01" class="form-control" required />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Base Quantity (for proportional calculation)</label>
                            <input name="BaseQuantity" type="number" step="0.01" value="1" class="form-control" required />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-toggle="modal">Close</button>
                        <button type="submit" class="btn btn-primary">Add Portion</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#imagePreview').attr('src', e.target.result).removeClass('d-none');
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
