@model RestroManagement.DbModels.MenuCategory

@{
    ViewData["Title"] = (Model?.Id > 0 ? "Edit" : "Create") + " Category";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-link p-0 text-decoration-none text-muted mb-2">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
    <h2 class="fw-bold">@ViewData["Title"]</h2>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card p-4">
            <form asp-action="@(Model?.Id > 0 ? "Edit" : "Create")">
                @if (Model?.Id > 0) { <input type="hidden" asp-for="Id" /> }
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Starters" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ImageUrl" class="form-label fw-semibold">Image URL (Optional)</label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                </div>

                <div class="mb-4">
                    <label asp-for="DisplayOrder" class="form-label fw-semibold"></label>
                    <input asp-for="DisplayOrder" class="form-control" type="number" />
                    <span asp-validation-for="DisplayOrder" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-check-lg"></i> Save Category
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
